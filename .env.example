# ── Groq API Key (FREE — for online LLM mode) ─────────────────────────────────
# Get your free key at: https://console.groq.com
# Sign up → API Keys → Create new key → paste it below
# This is OPTIONAL — only needed if USE_LOCAL_LLM = False in config.py
GROQ_API_KEY=your_groq_api_key_here

# ── Future keys (leave blank for now, will use in later phases) ───────────────
# RAPIDAPI_KEY=        # for LinkedIn job API (Phase 3)
# SMTP_EMAIL=          # for auto-sending emails (Phase 5)
# SMTP_PASSWORD=       # for auto-sending emails (Phase 5)